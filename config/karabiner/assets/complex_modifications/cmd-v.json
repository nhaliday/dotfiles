{
  "title": "Change cmd-G",
  "rules": [
    {
      "description": "Change cmd-G to cmd-V (fix for my broken Apple Magic Keyboard).",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "g",
            "modifiers": {
              "mandatory": [
                "command"
              ],
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "v",
              "modifiers": [
                "left_command"
              ]
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 1452,
                  "product_id": 591
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
